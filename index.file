<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Masters Pool 2026 — In Memory of Geoff Martyn</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Cormorant+Garamond:wght@400;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --green-deep: #0d2e1e; --green-mid: #1a5436; --gold: #c9a84c;
      --gold-light: #e2c47a; --cream: #f5f0e4; --white: #fdfbf6; --red: #c0392b;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--green-deep); color: var(--cream);
      font-family: 'Cormorant Garamond', serif; font-size: 16px; min-height: 100vh;
      background-image: radial-gradient(ellipse at 20% 0%, rgba(45,122,80,.25) 0%, transparent 60%);
    }
    header { text-align: center; padding: 40px 20px; border-bottom: 1px solid rgba(201,168,76,.25); }
    h1 { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 5vw, 3rem); color: var(--white); }
    h1 span { color: var(--gold); }
    .memorial { margin-top: 15px; display: inline-block; border: 1px solid var(--gold); padding: 5px 15px; font-style: italic; color: var(--gold-light); }
    .status-bar { display: flex; justify-content: space-between; align-items: center; max-width: 1200px; margin: 20px auto; padding: 10px 20px; background: rgba(0,0,0,0.2); border-radius: 4px; }
    .dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 5px; background: #666; }
    .dot.live { background: #4caf50; box-shadow: 0 0 8px #4caf50; }
    main { max-width: 1200px; margin: 0 auto; padding: 0 15px 50px; }
    .table-wrap { overflow-x: auto; border: 1px solid rgba(201,168,76,.3); border-radius: 8px; background: rgba(0,0,0,0.3); }
    table { width: 100%; border-collapse: collapse; min-width: 900px; }
    th { background: rgba(13,46,30,0.9); color: var(--gold); padding: 12px; text-align: left; text-transform: uppercase; font-size: 0.8rem; border-bottom: 1px solid var(--gold); }
    td { padding: 12px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .rank-cell { font-family: 'Playfair Display', serif; font-size: 1.4rem; color: var(--gold); font-weight: 700; text-align: center; }
    .owner-cell { font-weight: 600; color: var(--white); font-size: 1.1rem; }
    .golfer-name { display: block; font-size: 0.9rem; }
    .golfer-badge { font-size: 0.7rem; padding: 2px 6px; border-radius: 4px; background: rgba(201,168,76,0.15); color: var(--gold-light); }
    .score-cell { font-family: 'Playfair Display', serif; font-size: 1.5rem; text-align: center; color: var(--gold); }
    .mc { color: var(--red) !important; opacity: 0.8; }
    .refresh-btn { background: transparent; border: 1px solid var(--gold); color: var(--gold); padding: 5px 15px; cursor: pointer; }
  </style>
</head>
<body>

<header>
  <h1>Masters Pool <span>2026</span></h1>
  <div style="text-transform:uppercase; letter-spacing:2px; margin-top:5px;">Augusta National · April 9–12</div>
  <div class="memorial">In Memory of Geoff Martyn</div>
</header>

<div class="status-bar">
  <div><span class="dot" id="statusDot"></span> <span id="statusText">Awaiting Sync...</span></div>
  <div id="lastUpdate"></div>
  <button class="refresh-btn" onclick="loadData()">↻ Refresh</button>
</div>

<main id="mainContent">
  <div style="text-align:center; padding:100px;">⛳ Synchronizing Leaderboard...</div>
</main>

<script>
// ═══════════════════════════════════════════════════
//  DATA CONFIGURATION
// ═══════════════════════════════════════════════════
const ALIASES = { "scottie scheffler": "scott scheffler", "ludvig aberg": "ludvig åberg" };
const MC_PENALTY = 8;
const ESPN_URL = 'https://site.api.espn.com/apis/site/v2/sports/golf/leaderboard?league=pga';

const ALL_ENTRIES = [
  { owner:'Toph Kirland', golfers:['Xander Schauffele','Ludvig Aberg','Tommy Fleetwood','Cameron Young'] },
  { owner:'Vince Caporuscio', golfers:['Xander Schauffele','Cameron Young','Rory McIlroy','Ludvig Aberg'] },
  { owner:'Devin Kennedy', golfers:['Xander Schauffele','Matt Fitzpatrick','Tommy Fleetwood','Jon Rahm'] },
  { owner:'Brian Hegenbart 4', golfers:['Xander Schauffele','Akshay Bhatia','Cameron Young','Matt Fitzpatrick'] },
  { owner:'Bill Nunley', golfers:['Scottie Scheffler','Rory McIlroy','Jon Rahm','Bryson DeChambeau'] },
  { owner:'Brendan Glavin', golfers:['Scottie Scheffler','Bryson DeChambeau','Hideki Matsuyama','Justin Rose'] },
  { owner:'Brian Bateh 1', golfers:['Scottie Scheffler','Bryson DeChambeau','Rory McIlroy','Jon Rahm'] },
  { owner:'Brian Bateh 2', golfers:['Scottie Scheffler','Cameron Young','Jordan Spieth','Collin Morikawa'] },
  { owner:'Brian Hegenbart 2', golfers:['Scottie Scheffler','Xander Schauffele','Rory McIlroy','Jon Rahm'] },
  { owner:'Brian Hegenbart 3', golfers:['Scottie Scheffler','Ludvig Aberg','Bryson DeChambeau','Cameron Young'] },
  { owner:'Chris Haddock', golfers:['Scottie Scheffler','Rory McIlroy','Adam Scott','Jason Day'] },
  { owner:'Chris Kemph', golfers:['Scottie Scheffler','Rory McIlroy','Bryson DeChambeau','Patrick Cantlay'] },
  { owner:'Dan Chudd', golfers:['Scottie Scheffler','Bryson DeChambeau','Ludvig Aberg','Tommy Fleetwood'] },
  { owner:'Dan Murphy', golfers:['Scottie Scheffler','Jon Rahm','Patrick Reed','Xander Schauffele'] },
  { owner:'Gary Mann', golfers:['Scottie Scheffler','Justin Rose','Cameron Young','Tommy Fleetwood'] },
  { owner:'Greg Carnivale 1', golfers:['Scottie Scheffler','Rory McIlroy','Jon Rahm','Bryson DeChambeau'] },
  { owner:'Greg Carnivale 2', golfers:['Scottie Scheffler','Xander Schauffele','Ludvig Aberg','Jon Rahm'] },
  { owner:'Jim McEnerny 2', golfers:['Scottie Scheffler','Bryson DeChambeau','Hideki Matsuyama','Cameron Young'] },
  { owner:'Jim McEnerny 1', golfers:['Scottie Scheffler','Rory McIlroy','Xander Schauffele','Jon Rahm'] },
  { owner:'KC Arns 1', golfers:['Scottie Scheffler','Jon Rahm','Robert MacIntyre','Ludvig Aberg'] },
  { owner:'Keith Simpson', golfers:['Scottie Scheffler','Rory McIlroy','Jon Rahm','Xander Schauffele'] },
  { owner:'Matt Maher', golfers:['Scottie Scheffler','Ludvig Aberg','Cameron Young','Tommy Fleetwood'] },
  { owner:'Matt Wesmiller 2', golfers:['Scottie Scheffler','Ludvig Aberg','Akshay Bhatia','Bryson DeChambeau'] },
  { owner:'Michael Paluzzi', golfers:['Scottie Scheffler','Rory McIlroy','Bryson DeChambeau','Jon Rahm'] },
  { owner:'Mike Maher', golfers:['Scottie Scheffler','Matt Fitzpatrick','Robert MacIntyre','Jake Knapp'] },
  { owner:'Musa Farmand', golfers:['Scottie Scheffler','Bryson DeChambeau','Jon Rahm','Xander Schauffele'] },
  { owner:'Patrick McNamara', golfers:['Scottie Scheffler','Bryson DeChambeau','Rory McIlroy','Ludvig Aberg'] },
  { owner:'Paul Benninghof', golfers:['Scottie Scheffler','Jon Rahm','Xander Schauffele','Ludvig Aberg'] },
  { owner:'Ryan Bateman', golfers:['Scottie Scheffler','Ludvig Aberg','Jon Rahm','Xander Schauffele'] },
  { owner:'Chris Cook 1', golfers:['Scottie Scheffler','Ludvig Aberg','Xander Schauffele','Cameron Young'] },
  { owner:'Chris Roberson', golfers:['Scottie Scheffler','Xander Schauffele','Ludvig Aberg','Tommy Fleetwood'] },
  { owner:'Jimmy Trinh 2', golfers:['Scottie Scheffler','Jon Rahm','Bryson DeChambeau','Rory McIlroy'] },
  { owner:'Joe Greiner 1', golfers:['Scottie Scheffler','Tommy Fleetwood','Matt Fitzpatrick','Patrick Reed'] },
  { owner:'Michael Cooper', golfers:['Scottie Scheffler','Bryson DeChambeau','Jon Rahm','Justin Rose'] },
  { owner:'Rick Philbin', golfers:['Scottie Scheffler','Rory McIlroy','Bryson DeChambeau','Jon Rahm'] },
  { owner:'Ryan Fannon', golfers:['Scottie Scheffler','Bryson DeChambeau','Cameron Young','Tommy Fleetwood'] },
  { owner:'Dillon Kirland', golfers:['Scottie Scheffler','Xander Schauffele','Bryson DeChambeau','Jon Rahm'] },
  { owner:'Jeremy Malcolm 1', golfers:['Scottie Scheffler','Rory McIlroy','Cameron Young','J.J. Spaun'] },
  { owner:'Eric Glowniak', golfers:['Scottie Scheffler','Ludvig Aberg','Xander Schauffele','Corey Conners'] },
  { owner:'Nate Wood', golfers:['Scottie Scheffler','Xander Schauffele','Ludvig Aberg','Jon Rahm'] },
  { owner:'Chris Madison 3', golfers:['Scottie Scheffler','Jon Rahm','Jacob Bridgeman','Cameron Young'] },
  { owner:'Paul Arns', golfers:['Scottie Scheffler','Cameron Smith','Jordan Spieth','Matt Fitzpatrick'] },
  { owner:'Dave Mornhinweg', golfers:['Matt Fitzpatrick','Jon Rahm','Akshay Bhatia','Xander Schauffele'] },
  { owner:'Chris Meighan', golfers:['Justin Rose','Tommy Fleetwood','Ludvig Aberg','Viktor Hovland'] },
  { owner:'Cesar Santana', golfers:['Jon Rahm','Xander Schauffele','Cameron Young','Robert MacIntyre'] },
  { owner:'Mike Losasso', golfers:['Jon Rahm','Akshay Bhatia','Ludvig Aberg','Wyndham Clark'] },
  { owner:'Amy Beth Roy', golfers:['Cameron Young','Xander Schauffele','Ludvig Aberg','Maverick McNealy'] },
  { owner:'Chris Madison 2', golfers:['Cameron Young','Xander Schauffele','Justin Rose','Rory McIlroy'] },
  { owner:'Nick Canatsey', golfers:['Cameron Young','Matt Fitzpatrick','Xander Schauffele','Justin Rose'] },
  { owner:'Joe Greiner 2', golfers:['Bryson DeChambeau','Xander Schauffele','Jon Rahm','Cameron Young'] },
  { owner:'Gary Felice', golfers:['Bryson DeChambeau','Xander Schauffele','Jon Rahm','Sungjae Im'] },
  { owner:'Matt Wesmiller 1', golfers:['Bryson DeChambeau','Xander Schauffele','Matt Fitzpatrick','Patrick Reed'] },
  { owner:'Chad Hess 1', golfers:['Bryson DeChambeau','Xander Schauffele','Jordan Spieth','Jacob Bridgeman'] },
  { owner:'Chad Hess 3', golfers:['Bryson DeChambeau','Xander Schauffele','Patrick Reed','Jacob Bridgeman'] },
  { owner:'KC Arns 2', golfers:['Bryson DeChambeau','Rory McIlroy','Xander Schauffele','Tommy Fleetwood'] },
  { owner:'Chad Hess 2', golfers:['Bryson DeChambeau','Justin Rose','Matt Fitzpatrick','Xander Schauffele'] },
  { owner:'Robbie Salem', golfers:['Bryson DeChambeau','Cameron Young','Ludvig Aberg','Matt Fitzpatrick'] },
  { owner:'Brian Hegenbart 1', golfers:['Bryson DeChambeau','Xander Schauffele','Ludvig Aberg','Chris Gotterup'] },
  { owner:'Chris Cook 2', golfers:['Bryson DeChambeau','Ludvig Aberg','Tommy Fleetwood','Xander Schauffele'] },
  { owner:'Jeremy Malcolm 2', golfers:['Bryson DeChambeau','Xander Schauffele','Ludvig Aberg','Tommy Fleetwood'] },
  { owner:'Joe Murphy', golfers:['Bryson DeChambeau','Ludvig Aberg','Tommy Fleetwood','Patrick Reed'] },
  { owner:'Jack McCrery', golfers:['Bryson DeChambeau','Jon Rahm','Tommy Fleetwood','Patrick Reed'] },
  { owner:'Marquis Green', golfers:['Bryson DeChambeau','Jacob Bridgeman','Xander Schauffele','Jon Rahm'] },
  { owner:'Chris Madison 1', golfers:['Bryson DeChambeau','Matt Fitzpatrick','Ludvig Aberg','Cameron Young'] },
  { owner:'Josh Meighan', golfers:['Bryson DeChambeau','Cameron Young','Matt Fitzpatrick','Cameron Young'] },
  { owner:'Derek Toman', golfers:['Bryson DeChambeau','Ludvig Aberg','Justin Rose','Tommy Fleetwood'] },
  { owner:'Jimmy Trinh 1', golfers:['Bryson DeChambeau','Jon Rahm','Ludvig Aberg','Matt Fitzpatrick'] },
  { owner:'Jason Paul', golfers:['Bryson DeChambeau','Justin Rose','Ludvig Aberg','Rory McIlroy'] },
  { owner:'Ash Johnston', golfers:['Bryson DeChambeau','Patrick Reed','Matt Fitzpatrick','Xander Schauffele'] },
  { owner:'John Durastanti', golfers:['Bryson DeChambeau','Cameron Young','Justin Rose','Xander Schauffele'] },
];

// ═══════════════════════════════════════════════════
//  ENGINE
// ═══════════════════════════════════════════════════

function normalize(name) {
  let n = (name || "").toLowerCase().trim();
  return ALIASES[n] || n;
}

async function loadData() {
  const dot = document.getElementById('statusDot');
  const txt = document.getElementById('statusText');
  dot.className = 'dot';
  txt.textContent = 'Syncing...';

  try {
    const proxy = 'https://api.allorigins.win/get?url=' + encodeURIComponent(ESPN_URL + '&t=' + Date.now());
    const resp = await fetch(proxy);
    const json = await resp.json();
    const data = JSON.parse(json.contents);
    const athletes = data.events[0].competitions[0].competitors;

    // Waterfall Extract Leaderboard
    const lb = athletes.map(p => {
      try {
        const s = p.status || {};
        const scoreVal = p.score?.value ?? 0;
        const posStr = p.position?.displayValue || "";
        const posParsed = parseInt(posStr.replace(/[^0-9]/g,''), 10);
        
        return {
          name: p.athlete.displayName.toLowerCase(),
          score: scoreVal,
          rawRank: p.order || (!isNaN(posParsed) ? posParsed : null),
          isMC: s.type?.name?.toLowerCase().includes('cut') || s.type?.name?.toLowerCase().includes('mc'),
          thru: s.thru || 'F'
        };
      } catch(e) { return null; }
    }).filter(x => x);

    // Calculate MC Penalty based on actual finishers
    const finisherCount = lb.filter(p => !p.isMC).length;
    const mcScoreValue = (finisherCount + 1) + MC_PENALTY;

    // Sort to establish accurate Ranks if p.order is missing
    const sortedActive = [...lb].filter(p => !p.isMC).sort((a,b) => a.score - b.score);
    let currentRank = 1;
    sortedActive.forEach((p, i) => {
      if (i > 0 && p.score !== sortedActive[i-1].score) currentRank = i + 1;
      p.rank = currentRank;
    });

    // Match Entries to Leaderboard
    const finalData = ALL_ENTRIES.map(entry => {
      const resolvedGolfers = entry.golfers.map(gName => {
        const target = normalize(gName);
        const match = lb.find(p => p.name.includes(target) || target.includes(p.name));
        
        if (!match) return { name: gName, rank: 99, score: '??', thru: '--' };
        if (match.isMC) return { name: gName, rank: mcScoreValue, score: 'MC', isMC: true, thru: 'F' };
        
        return { 
          name: gName, 
          rank: match.rank, 
          score: match.score === 0 ? 'E' : (match.score > 0 ? '+' + match.score : match.score),
          thru: match.thru
        };
      });

      const total = resolvedGolfers.reduce((sum, g) => sum + (g.rank || 0), 0);
      return { owner: entry.owner, golfers: resolvedGolfers, total: total };
    });

    render(finalData.sort((a,b) => a.total - b.total));

    dot.className = 'dot live';
    txt.textContent = 'Live Data';
    document.getElementById('lastUpdate').textContent = 'Last Sync: ' + new Date().toLocaleTimeString();

  } catch (err) {
    console.error("Sync Error:", err);
    txt.textContent = 'Sync Offline';
    dot.className = 'dot';
  }
}

function render(data) {
  let html = `
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Rank</th>
            <th>Entry</th>
            <th>G1</th>
            <th>G2</th>
            <th>G3</th>
            <th>G4</th>
            <th style="text-align:center">Total</th>
          </tr>
        </thead>
        <tbody>`;

  data.forEach((e, i) => {
    const tied = (i > 0 && e.total === data[i-1].total);
    const rankLabel = tied ? "" : (i + 1);
    
    html += `
      <tr>
        <td class="rank-cell">${rankLabel}</td>
        <td class="owner-cell">${e.owner}</td>
        ${e.golfers.map(g => `
          <td>
            <span class="golfer-name ${g.isMC ? 'mc' : ''}">${g.name}</span>
            <span class="golfer-badge ${g.isMC ? 'mc' : ''}">${g.score} · Thru ${g.thru}</span>
          </td>
        `).join('')}
        <td class="score-cell">${e.total}</td>
      </tr>`;
  });

  html += '</tbody></table></div>';
  document.getElementById('mainContent').innerHTML = html;
}

// Global Execution
loadData();
setInterval(loadData, 120000);
</script>
</body>
</html>
